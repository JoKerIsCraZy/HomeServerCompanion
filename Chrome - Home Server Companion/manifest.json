{
  "manifest_version": 3,
  "name": "Home Server Companion",
  "version": "4.0.0",
  "description": "Unified dashboard for your home server services with Dark Pro UI",
  "permissions": ["storage", "contextMenus", "declarativeNetRequest"],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://ipwho.is/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; form-action 'none'; frame-src 'none'"
  }
}
