{
  "manifest_version": 3,
  "name": "Home Server Companion",
  "version": "3.5",
  "description": "Manage Unraid, Tautulli, SABnzbd, and a couple of -rr services",
  "permissions": ["storage", "contextMenus"],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://ipwho.is/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
